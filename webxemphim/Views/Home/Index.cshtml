@{
    if (ViewData != null)
    {
        ViewData["Title"] = "Trang Chủ";
    }
}

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #0a0a0a;
        color: #fff;
        overflow-x: hidden;
    }

    /* ===== HERO BANNER ===== */
    .hero-banner {
        position: relative;
        width: 100%;
        height: 500px;
        background-image: url('/images/natra/natrah2.jpg');
        background-size: cover;
        background-position: center top;
        overflow: hidden;
    }

    .hero-gradient-left {
        position: absolute;
        top: 0; left: 0;
        width: 60%;
        height: 100%;
        background: linear-gradient(to right, rgba(10,10,10,0.95) 30%, transparent 100%);
        z-index: 1;
    }

    .hero-gradient-bottom {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 120px;
        background: linear-gradient(to top, #0a0a0a, transparent);
        z-index: 1;
    }

    .hero-content {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        z-index: 2;
        display: flex;
        align-items: flex-end;
        padding: 0 48px 32px;
        box-sizing: border-box;
        justify-content: space-between;
    }

    .hero-info {
        max-width: 480px;
    }

    .hero-title {
        font-size: 36px;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 4px;
        line-height: 1.2;
    }

    .hero-subtitle {
        font-size: 14px;
        color: #aaa;
        margin: 0 0 12px;
    }

    .hero-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.3);
        color: #fff;
        background: rgba(255,255,255,0.1);
    }

    .badge.fhd { background: #1a73e8; border-color: #1a73e8; }
    .badge.age { background: transparent; border-color: #aaa; color: #aaa; }

    .hero-genres {
        display: flex;
        gap: 8px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }

    .genre-dot {
        font-size: 13px;
        color: #ccc;
    }

    .genre-dot::before {
        content: '· ';
    }

    .genre-dot:first-child::before {
        content: '';
    }

    .hero-desc {
        font-size: 13px;
        color: #bbb;
        line-height: 1.6;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-play {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #f5a623;
        border: none;
        color: #fff;
        font-size: 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-play:hover { background: #e09510; }

    .btn-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        color: #fff;
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-icon:hover { background: rgba(255,255,255,0.25); }

    /* Thumbnail carousel bên phải */
    .hero-thumbnails {
        display: flex;
        gap: 8px;
        align-items: flex-end;
        padding-bottom: 4px;
    }

    .thumb-item {
        width: 80px;
        height: 52px;
        border-radius: 6px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: border 0.2s;
        flex-shrink: 0;
    }

    .thumb-item:hover, .thumb-item.active {
        border-color: #f5a623;
    }

    .thumb-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* ===== MOVIE SECTIONS ===== */
    .page-body {
        padding: 24px 48px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #fff;
        margin: 0;
    }

    .section-more {
        font-size: 13px;
        color: #aaa;
        text-decoration: none;
        transition: color 0.2s;
    }

    .section-more:hover { color: #f5a623; }

    .movies-row {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        padding-bottom: 8px;
        scrollbar-width: thin;
        scrollbar-color: #333 transparent;
    }

    .movies-row::-webkit-scrollbar { height: 4px; }
    .movies-row::-webkit-scrollbar-track { background: transparent; }
    .movies-row::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }

    .movie-card {
        flex-shrink: 0;
        width: 160px;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .movie-card:hover { transform: scale(1.04); }

    .movie-card img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-radius: 8px;
        display: block;
    }

    .movie-card-info {
        padding: 8px 2px 0;
    }

    .movie-card-title {
        font-size: 13px;
        font-weight: 600;
        color: #eee;
        margin: 0 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .movie-card-meta {
        font-size: 11px;
        color: #888;
    }

    .movie-card-badge {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        padding: 1px 5px;
        border-radius: 3px;
        background: #1a73e8;
        color: #fff;
        margin-right: 4px;
    }

    .section-divider {
        height: 1px;
        background: rgba(255,255,255,0.06);
        margin: 32px 0;
    }

    @@media (max-width: 768px) {
        .hero-banner { height: 380px; }
        .hero-content { padding: 0 20px 24px; flex-direction: column; align-items: flex-start; justify-content: flex-end; gap: 12px; }
        .hero-thumbnails { display: none; }
        .hero-title { font-size: 26px; }
        .page-body { padding: 16px 16px; }
        .movie-card { width: 130px; }
        .movie-card img { height: 180px; }
    }
</style>

<!-- HERO BANNER -->
<div class="hero-banner">
