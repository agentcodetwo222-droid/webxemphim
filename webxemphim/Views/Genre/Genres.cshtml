    });

    // Genre link click events
    document.querySelectorAll('.genre-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.stopPropagation();
            const name = this.parentElement.querySelector('.genre-name').textContent;
            console.log('View all for genre:', name);
            // Add your navigation logic here
        });
    });
</script> 