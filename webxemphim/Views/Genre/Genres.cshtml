@{
    ViewData["Title"] = "Thể loại";
}

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0f0f0f 100%);
        color: #fff;
        min-height: 100vh;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .page-title {
        font-size: 32px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 40px;
        text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
    }

    .genres-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .genre-column {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .genre-item {
        padding: 12px 16px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s;
        position: relative;
        background: rgba(35, 37, 51, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .genre-item:hover {
        background: rgba(35, 37, 51, 0.6);
        transform: translateX(4px);
    }

    .genre-item.active {
        background: linear-gradient(135deg, rgba(35, 37, 51, 0.8) 0%, rgba(45, 55, 72, 0.8) 100%);
        border: 1px solid rgba(255, 215, 0, 0.3);
        box-shadow: 0 4px 12px rgba(255, 215, 0, 0.2);
    }

    .genre-name {
        font-size: 14px;
        font-weight: 500;
        color: #fff;
        margin-bottom: 4px;
    }

    .genre-link {
        font-size: 12px;
        color: #ffd700;
        text-decoration: none;
        transition: all 0.3s;
    }

    .genre-link:hover {
        color: #ffed4e;
        text-shadow: 0 0 8px rgba(255, 215, 0, 0.5);
    }

    .back-btn {
        position: absolute;
        top: 20px;
        left: 20px;
        background: linear-gradient(135deg, rgba(35, 37, 51, 0.8) 0%, rgba(45, 55, 72, 0.8) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        padding: 12px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.3s;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        z-index: 10;
    }

    .back-btn:hover {
        background: linear-gradient(135deg, rgba(45, 55, 72, 0.9) 0%, rgba(55, 65, 82, 0.9) 100%);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
        color: #ffd700;
    }

    /* Responsive Design */
    @@media screen and (max-width: 1024px) {
        .genres-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media screen and (max-width: 768px) {
        .genres-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        .genre-item {
            padding: 10px 14px;
        }
    }

    @@media screen and (max-width: 480px) {
        .container {
            padding: 20px 10px;
        }

        .page-title {
            font-size: 28px;
            margin-bottom: 30px;
        }

        .genres-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .genre-item {
            padding: 12px 16px;
        }

        .genre-name {
            font-size: 13px;
        }

        .genre-link {
            font-size: 11px;
        }
    }
</style>

