@section Scripts {
<script>
const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
let lastEncrypted = '';

async function post(url, body) {
    const r = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
        body: JSON.stringify(body)
    });
    return r.json();
}

function spin(id, on) {
    document.getElementById(id).style.display = on ? 'inline-block' : 'none';
}

function fillSample() {
    const samples = [
        'dat135799a@gmail.com',
        '0987654321',
        '/videos/natra/natra2.mp4',
        '50000',
        'HĂ  Ná»™i, Viá»‡t Nam'
    ];
    document.getElementById('enc-input').value = samples[Math.floor(Math.random() * samples.length)];
}

async function doEncrypt() {
    const plaintext = document.getElementById('enc-input').value.trim();
    if (!plaintext) return alert('Vui lĂ²ng nháº­p dá»¯ liá»‡u!');
    spin('enc-spinner', true);
    const d = await post('/Security/Encrypt', { plaintext });
    spin('enc-spinner', false);
    if (d.error) return alert(d.error);

    lastEncrypted = d.encrypted;
    document.getElementById('r-nonce').textContent     = d.nonce_hex;
    document.getElementById('r-tag').textContent       = d.tag_hex;
    document.getElementById('r-stats').innerHTML       =
        `Input: ${d.input_bytes}B<br>Output: ${d.output_bytes}B<br>+${d.output_bytes - d.input_bytes}B overhead`;
    document.getElementById('r-cipher').textContent    = d.cipher_hex;
    document.getElementById('r-encrypted').textContent = d.encrypted;
    document.getElementById('enc-timing').textContent  = `â± MĂ£ hĂ³a trong ${d.elapsed_ms}ms lĂºc ${d.timestamp} UTC`;
    document.getElementById('enc-result').style.display = 'block';
}

function copyToDecrypt() {
    if (!lastEncrypted) return;
    document.getElementById('dec-input').value = lastEncrypted;
    document.getElementById('dec-result').style.display = 'none';
    document.querySelector('.card:nth-child(3)').scrollIntoView({ behavior: 'smooth' });
}

async function doDecrypt() {
    const ciphertext = document.getElementById('dec-input').value.trim();
    if (!ciphertext) return alert('Vui lĂ²ng dĂ¡n chuá»—i Base64!');
    spin('dec-spinner', true);
    const d = await post('/Security/Decrypt', { ciphertext });
    spin('dec-spinner', false);

    const box = document.getElementById('r-decrypted');
    const vfy = document.getElementById('r-verify');

    if (d.verified) {
        box.textContent = d.decrypted;
        box.className   = 'result-box ok-box';
        vfy.innerHTML   = '<span class="badge-ok">âœ… Auth Tag khá»›p â€” dá»¯ liá»‡u toĂ n váº¹n</span>';
    } else {
        box.textContent = d.error || 'Giáº£i mĂ£ tháº¥t báº¡i';
        box.className   = 'result-box fail-box';
        vfy.innerHTML   = '<span class="badge-fail">âŒ Auth Tag KHĂ”NG khá»›p â€” dá»¯ liá»‡u Ä‘Ă£ bá»‹ sá»­a Ä‘á»•i!</span>';
    }
    document.getElementById('dec-timing').textContent  =
        d.elapsed_ms ? `â± Giáº£i mĂ£ trong ${d.elapsed_ms}ms lĂºc ${d.timestamp} UTC` : '';
    document.getElementById('dec-result').style.display = 'block';
}

async function tamperAndDecrypt() {
    const ciphertext = document.getElementById('dec-input').value.trim();
    if (!ciphertext) return alert('Cáº§n cĂ³ chuá»—i Base64 á»Ÿ Ă´ giáº£i mĂ£ trÆ°á»›c!');

    // Sá»­a 1 kĂ½ tá»± á»Ÿ giá»¯a Ä‘á»ƒ mĂ´ phá»ng táº¥n cĂ´ng
    const arr   = ciphertext.split('');
    const mid   = Math.floor(arr.length / 2);
    arr[mid]    = arr[mid] === 'A' ? 'B' : 'A';
    const tampered = arr.join('');

    document.getElementById('dec-input').value = tampered + ' â† (Ä‘Ă£ bá»‹ sá»­a 1 kĂ½ tá»±)';
    spin('dec-spinner', true);
    const d = await post('/Security/Decrypt', { ciphertext: tampered });
    spin('dec-spinner', false);

    const box = document.getElementById('r-decrypted');
    const vfy = document.getElementById('r-verify');
    box.textContent = d.error || 'Giáº£i mĂ£ tháº¥t báº¡i â€” Auth Tag khĂ´ng khá»›p';
    box.className   = 'result-box fail-box';
    vfy.innerHTML   = '<span class="badge-fail">âŒ Táº¥n cĂ´ng phĂ¡t hiá»‡n! AES-GCM tá»« chá»‘i giáº£i mĂ£ dá»¯ liá»‡u bá»‹ sá»­a Ä‘á»•i.</span>';
    document.getElementById('dec-result').style.display = 'block';
}

async function doSimulate() {
    const plaintext = document.getElementById('sim-input').value.trim();
    if (!plaintext) return alert('Vui lĂ²ng nháº­p dá»¯ liá»‡u!');
    spin('sim-spinner', true);
    const d = await post('/Security/SimulateToken', { plaintext });
    spin('sim-spinner', false);

    let html = '';
    for (const s of d.steps) {
        html += `<div class="step-item">
            <div class="step-num">${s.step}</div>
            <div style="flex:1">
                <div class="step-label">${s.label}</div>
                <div class="step-value">${s.value}</div>
                <div class="step-note">${s.note}</div>
            </div>
        </div>`;
    }
    document.getElementById('sim-steps').innerHTML = html;
    document.getElementById('sim-timing').textContent = `â± HoĂ n thĂ nh lĂºc ${d.timestamp} UTC`;
    document.getElementById('sim-result').style.display = 'block';
}
</script>
}

