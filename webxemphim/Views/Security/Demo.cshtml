.step-label { font-weight: bold; color: #fff; font-size: 0.9rem; }
.step-value { font-family: monospace; font-size: 0.78rem; color: #7fdbff; word-break: break-all; margin: 4px 0; background: #1a1b2a; padding: 6px 8px; border-radius: 6px; }
.step-note  { font-size: 0.75rem; color: #888; }
.badge-ok   { background: #1a472a; color: #2ecc71; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; }
.badge-fail { background: #4a0000; color: #e74c3c; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; }
.timing     { color: #666; font-size: 0.75rem; margin-top: 8px; }
.spinner    { display: none; width: 16px; height: 16px; border: 2px solid #444; border-top-color: #ffd700; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; }
@@keyframes spin { to { transform: rotate(360deg); } }
.code-block { background: #0d1117; border: 1px solid #333; border-radius: 8px; padding: 14px 16px; font-family: monospace; font-size: 0.8rem; line-height: 1.7; overflow-x: auto; }
.kw  { color: #ff7b72; }
.fn  { color: #d2a8ff; }
.cm  { color: #8b949e; }
.str { color: #a5d6ff; }
.num { color: #79c0ff; }
</style>

