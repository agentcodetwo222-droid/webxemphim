@{
    ViewData["Title"] = "Xem cach hoat dong SSTP";
    var role = Context.Session.GetString("UserRole");
    if (role != "Admin")
    {
        Context.Response.Redirect("/");
        return;
    }
}
@Html.AntiForgeryToken()

<style>
.demo-page  { max-width: 1100px; margin: 0 auto; padding: 32px 16px; }
.demo-title { font-size: 1.8rem; font-weight: bold; color: #ffd700; margin-bottom: 6px; }
.demo-sub   { color: #aaa; font-size: 0.9rem; margin-bottom: 28px; }
.card       { background: #232533; border-radius: 12px; padding: 20px 24px; margin-bottom: 20px; border: 1px solid #333; }
.card-title { font-weight: bold; color: #ffd700; margin-bottom: 14px; font-size: 1rem; border-bottom: 1px solid #333; padding-bottom: 8px; }
.flabel     { color: #aaa; font-size: 0.78rem; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
textarea, input[type=text] {
    width: 100%; background: #1a1b2a; border: 1px solid #444; color: #fff;
    border-radius: 8px; padding: 10px 12px; font-size: 0.9rem; font-family: monospace;
    resize: vertical; outline: none; box-sizing: border-box;
}
textarea:focus, input[type=text]:focus { border-color: #ffd700; }
.btn        { padding: 9px 22px; border-radius: 8px; border: none; font-weight: bold; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
.btn-gold   { background: #ffd700; color: #232533; }
.btn-gold:hover  { background: #ffed4e; }
.btn-blue   { background: #2980b9; color: #fff; }
.btn-blue:hover  { background: #3498db; }
.btn-green  { background: #1a6b3a; color: #2ecc71; border: 1px solid #2ecc71; }
.btn-green:hover { background: #1e8449; }
.btn-red    { background: #6b1a1a; color: #e74c3c; border: 1px solid #e74c3c; }
.rbox       { background: #1a1b2a; border: 1px solid #444; border-radius: 8px; padding: 12px; font-family: monospace; font-size: 0.8rem; word-break: break-all; min-height: 40px; color: #7fdbff; }
.rbox-hex   { color: #f39c12; }
.rbox-ok    { border-color: #2ecc71; color: #2ecc71; }
.rbox-fail  { border-color: #e74c3c; color: #e74c3c; }
.g3         { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
@@media(max-width:768px) { .g3 { grid-template-columns: 1fr; } }
.step-row   { display: flex; gap: 12px; padding: 12px 0; border-bottom: 1px solid #2a2b3a; }
.step-row:last-child { border-bottom: none; }
.step-num   { background: #ffd700; color: #232533; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.85rem; flex-shrink: 0; }
.step-lbl   { font-weight: bold; color: #fff; font-size: 0.9rem; }
.step-val   { font-family: monospace; font-size: 0.78rem; color: #7fdbff; word-break: break-all; margin: 4px 0; background: #1a1b2a; padding: 6px 8px; border-radius: 6px; }
.step-note  { font-size: 0.75rem; color: #888; }
.bok        { background: #1a472a; color: #2ecc71; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; }
.bfail      { background: #4a0000; color: #e74c3c; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; }
.timing     { color: #666; font-size: 0.75rem; margin-top: 8px; }
.spinner    { display: none; width: 16px; height: 16px; border: 2px solid #444; border-top-color: #ffd700; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; vertical-align: middle; }
@@keyframes spin { to { transform: rotate(360deg); } }
.codeblock  { background: #0d1117; border: 1px solid #333; border-radius: 8px; padding: 14px 16px; font-family: monospace; font-size: 0.8rem; line-height: 1.7; overflow-x: auto; }
.kw  { color: #ff7b72; }
.fn  { color: #d2a8ff; }
.cm  { color: #8b949e; }
.num { color: #79c0ff; }
</style>

<div class="demo-page">

<div class="demo-title"><i class="fas fa-eye"></i> Xem cach hoat dong AES-256-GCM</div>
<div class="demo-sub">Demo real-time &mdash; ma hoa / giai ma truc tiep bang code thuc te &middot; Chi Admin</div>

@* ── CARD 1: Ma hoa ────────────────────────────────────────────────────── *@
<div class="card">
    <div class="card-title"><i class="fas fa-lock"></i> 1. Ma hoa Plaintext &#8594; Ciphertext (Real-time)</div>
    <div class="flabel">Nhap du lieu can ma hoa</div>
    <textarea id="enc-input" rows="3" placeholder="Vi du: email@gmail.com / 50000 / /videos/natra.mp4"></textarea>
    <div style="margin-top:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <button class="btn btn-gold" onclick="doEncrypt()"><i class="fas fa-lock"></i> Ma hoa ngay</button>
        <button class="btn btn-blue" onclick="fillSample()">Dung du lieu mau</button>
        <div class="spinner" id="enc-spin"></div>
    </div>
    <div id="enc-result" style="display:none;margin-top:16px;">
        <div class="g3" style="margin-bottom:12px;">
            <div>
                <div class="flabel">Nonce (96-bit &#8212; ngau nhien)</div>
                <div class="rbox rbox-hex" id="r-nonce"></div>
            </div>
            <div>
                <div class="flabel">Auth Tag (128-bit)</div>
                <div class="rbox rbox-hex" id="r-tag"></div>
            </div>
            <div>
                <div class="flabel">Thong ke</div>
                <div class="rbox" id="r-stats"></div>
            </div>
        </div>
        <div class="flabel">Ciphertext (HEX)</div>
        <div class="rbox rbox-hex" id="r-cipher" style="margin-bottom:10px;"></div>
        <div class="flabel">Output luu Database (Base64 = Nonce + Tag + Cipher)</div>
        <div class="rbox" id="r-encrypted" style="margin-bottom:10px;"></div>
        <button class="btn btn-green" onclick="copyToDecrypt()">
            <i class="fas fa-arrow-down"></i> Copy sang o Giai ma
        </button>
        <div class="timing" id="enc-time"></div>
    </div>
</div>

@* ── CARD 2: Giai ma ────────────────────────────────────────────────────── *@
<div class="card">
    <div class="card-title"><i class="fas fa-unlock"></i> 2. Giai ma Ciphertext &#8594; Plaintext (Real-time)</div>
    <div class="flabel">Dan chuoi Base64 tu Database</div>
    <textarea id="dec-input" rows="3" placeholder="Dan chuoi Base64 da ma hoa vao day..."></textarea>
    <div style="margin-top:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <button class="btn btn-green" onclick="doDecrypt()"><i class="fas fa-unlock"></i> Giai ma ngay</button>
        <button class="btn btn-red" onclick="tamperTest()"><i class="fas fa-bug"></i> Gia lap tan cong (sua 1 byte)</button>
        <div class="spinner" id="dec-spin"></div>
    </div>
    <div id="dec-result" style="display:none;margin-top:16px;">
        <div class="flabel">Ket qua giai ma</div>
        <div class="rbox" id="r-decrypted" style="margin-bottom:10px;font-size:1rem;"></div>
        <div id="r-verify"></div>
        <div class="timing" id="dec-time"></div>
    </div>
</div>

@* ── CARD 3: Mo phong ────────────────────────────────────────────────────── *@
<div class="card">
    <div class="card-title"><i class="fas fa-project-diagram"></i> 3. Mo phong toan bo luong ma hoa tung buoc</div>
    <div class="flabel">Du lieu dau vao</div>
    <input type="text" id="sim-input" value="50000" placeholder="Vi du: 50000" />
    <div style="margin-top:10px;display:flex;align-items:center;gap:10px;">
        <button class="btn btn-gold" onclick="doSimulate()"><i class="fas fa-play"></i> Chay mo phong</button>
        <div class="spinner" id="sim-spin"></div>
    </div>
    <div id="sim-result" style="display:none;margin-top:16px;">
        <div id="sim-steps"></div>
        <div class="timing" id="sim-time"></div>
    </div>
</div>

@* ── CARD 4: Source code ─────────────────────────────────────────────────── *@
<div class="card">
    <div class="card-title"><i class="fas fa-code"></i> 4. Source code thuc te (EncryptionService.cs)</div>
    <div class="codeblock">
<span class="cm">// AES-256-GCM -- NIST SP 800-38D -- dung trong TLS 1.3 / SSTP</span>
<span class="kw">public string</span> <span class="fn">Encrypt</span>(<span class="kw">string</span> plaintext)
{
    <span class="kw">var</span> plaintextBytes = Encoding.UTF8.GetBytes(plaintext);
    <span class="kw">var</span> nonce      = <span class="kw">new byte</span>[<span class="num">12</span>];  <span class="cm">// 96-bit nonce</span>
    <span class="kw">var</span> tag        = <span class="kw">new byte</span>[<span class="num">16</span>];  <span class="cm">// 128-bit auth tag</span>
    <span class="kw">var</span> ciphertext = <span class="kw">new byte</span>[plaintextBytes.Length];

    <span class="cm">// Nonce ngau nhien moi lan -- khong tai dung voi AES-GCM</span>
    RandomNumberGenerator.Fill(nonce);

    <span class="kw">using var</span> aesGcm = <span class="kw">new</span> AesGcm(_key, <span class="num">16</span>);
    aesGcm.Encrypt(nonce, plaintextBytes, ciphertext, tag);

    <span class="cm">// Dong goi: nonce[12] + tag[16] + ciphertext --> Base64</span>
    <span class="kw">var</span> combined = <span class="kw">new byte</span>[<span class="num">28</span> + ciphertext.Length];
    Buffer.BlockCopy(nonce,      <span class="num">0</span>, combined, <span class="num">0</span>,  <span class="num">12</span>);
    Buffer.BlockCopy(tag,        <span class="num">0</span>, combined, <span class="num">12</span>, <span class="num">16</span>);
    Buffer.BlockCopy(ciphertext, <span class="num">0</span>, combined, <span class="num">28</span>, ciphertext.Length);
    <span class="kw">return</span> Convert.ToBase64String(combined);
}

<span class="kw">public string</span> <span class="fn">Decrypt</span>(<span class="kw">string</span> encryptedBase64)
{
    <span class="kw">var</span> combined   = Convert.FromBase64String(encryptedBase64);
    <span class="kw">var</span> nonce      = combined[..<span class="num">12</span>];    <span class="cm">// tach Nonce</span>
    <span class="kw">var</span> tag        = combined[<span class="num">12</span>..<span class="num">28</span>];  <span class="cm">// tach Auth Tag</span>
    <span class="kw">var</span> ciphertext = combined[<span class="num">28</span>..];    <span class="cm">// tach Ciphertext</span>
    <span class="kw">var</span> plaintext  = <span class="kw">new byte</span>[ciphertext.Length];

    <span class="kw">using var</span> aesGcm = <span class="kw">new</span> AesGcm(_key, <span class="num">16</span>);
    <span class="cm">// Verify Tag truoc -- neu DB bi sua thi throw ngay</span>
    aesGcm.Decrypt(nonce, ciphertext, tag, plaintext);
    <span class="kw">return</span> Encoding.UTF8.GetString(plaintext);
}
    </div>
</div>

<div style="text-align:right;margin-top:8px;">
    <a href="/Security" style="color:#aaa;font-size:0.85rem;">&larr; Test SSTP Status</a>
    &nbsp;|&nbsp;
    <a href="/" style="color:#aaa;font-size:0.85rem;">&larr; Trang chu</a>
</div>

</div>

@section Scripts {
<script>
const _tk = document.querySelector('input[name="__RequestVerificationToken"]').value;
let _lastEnc = '';

async function callApi(url, body) {
    const r = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': _tk },
        body: JSON.stringify(body)
    });
    return r.json();
}

function spin(id, on) { document.getElementById(id).style.display = on ? 'inline-block' : 'none'; }
function show(id)     { document.getElementById(id).style.display = 'block'; }
function el(id)       { return document.getElementById(id); }

function fillSample() {
    const s = ['email@gmail.com', '0987654321', '/videos/natra.mp4', '50000', 'Ha Noi'];
    el('enc-input').value = s[Math.floor(Math.random() * s.length)];
}

async function doEncrypt() {
    const pt = el('enc-input').value.trim();
    if (!pt) return alert('Vui long nhap du lieu!');
    spin('enc-spin', true);
    const d = await callApi('/Security/Encrypt', { plaintext: pt });
    spin('enc-spin', false);
    if (d.error) return alert(d.error);
    _lastEnc = d.encrypted;
    el('r-nonce').textContent     = d.nonce_hex;
    el('r-tag').textContent       = d.tag_hex;
    el('r-stats').innerHTML       = 'Input: ' + d.input_bytes + 'B<br>Output: ' + d.output_bytes + 'B<br>+' + (d.output_bytes - d.input_bytes) + 'B overhead';
    el('r-cipher').textContent    = d.cipher_hex;
    el('r-encrypted').textContent = d.encrypted;
    el('enc-time').textContent    = 'Ma hoa trong ' + d.elapsed_ms + 'ms luc ' + d.timestamp + ' UTC';
    show('enc-result');
}

function copyToDecrypt() {
    if (!_lastEnc) return;
    el('dec-input').value = _lastEnc;
    el('dec-result').style.display = 'none';
}

async function doDecrypt() {
    const ct = el('dec-input').value.trim();
    if (!ct) return alert('Vui long dan chuoi Base64!');
    spin('dec-spin', true);
    const d = await callApi('/Security/Decrypt', { ciphertext: ct });
    spin('dec-spin', false);
    const box = el('r-decrypted');
    const vfy = el('r-verify');
    if (d.verified) {
        box.textContent = d.decrypted;
        box.className   = 'rbox rbox-ok';
        vfy.innerHTML   = '<span class="bok">&#10003; Auth Tag khop - du lieu toan ven</span>';
    } else {
        box.textContent = d.error || 'Giai ma that bai';
        box.className   = 'rbox rbox-fail';
        vfy.innerHTML   = '<span class="bfail">&#10007; Auth Tag KHONG khop - du lieu da bi sua doi!</span>';
    }
    el('dec-time').textContent = d.elapsed_ms ? 'Giai ma trong ' + d.elapsed_ms + 'ms luc ' + d.timestamp + ' UTC' : '';
    show('dec-result');
}

async function tamperTest() {
    const ct = el('dec-input').value.trim();
    if (!ct) return alert('Can co chuoi Base64 o o giai ma truoc!');
    const a   = ct.split('');
    const mid = Math.floor(a.length / 2);
    a[mid]    = a[mid] === 'A' ? 'B' : 'A';
    el('dec-input').value = a.join('');
    spin('dec-spin', true);
    await callApi('/Security/Decrypt', { ciphertext: a.join('') });
    spin('dec-spin', false);
    el('r-decrypted').textContent = 'Tan cong phat hien! AES-GCM tu choi giai ma du lieu bi sua doi.';
    el('r-decrypted').className   = 'rbox rbox-fail';
    el('r-verify').innerHTML      = '<span class="bfail">&#10007; Auth Tag KHONG khop - he thong bao ve thanh cong!</span>';
    show('dec-result');
}

async function doSimulate() {
    const pt = el('sim-input').value.trim();
    if (!pt) return alert('Vui long nhap du lieu!');
    spin('sim-spin', true);
    const d = await callApi('/Security/SimulateToken', { plaintext: pt });
    spin('sim-spin', false);
    let html = '';
    for (const s of d.steps) {
        html += '<div class="step-row">'
             +  '<div class="step-num">' + s.step + '</div>'
             +  '<div style="flex:1">'
             +  '<div class="step-lbl">' + s.label + '</div>'
             +  '<div class="step-val">'  + s.value + '</div>'
             +  '<div class="step-note">' + s.note  + '</div>'
             +  '</div></div>';
    }
    el('sim-steps').innerHTML      = html;
    el('sim-time').textContent     = 'Hoan thanh luc ' + d.timestamp + ' UTC';
    show('sim-result');
}
</script>
}
