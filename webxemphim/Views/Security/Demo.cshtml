        <div class="code-block">
<span class="cm">/// AES-256-GCM â€” NIST SP 800-38D â€” dĂ¹ng trong TLS 1.3 / SSTP</span>
<span class="kw">public string</span> <span class="fn">Encrypt</span>(<span class="kw">string</span> plaintext)
{
    <span class="kw">var</span> plaintextBytes = Encoding.UTF8.<span class="fn">GetBytes</span>(plaintext);
    <span class="kw">var</span> nonce          = <span class="kw">new byte</span>[<span class="num">12</span>];  <span class="cm">// 96-bit</span>
    <span class="kw">var</span> tag            = <span class="kw">new byte</span>[<span class="num">16</span>];  <span class="cm">// 128-bit auth tag</span>
    <span class="kw">var</span> ciphertext     = <span class="kw">new byte</span>[plaintextBytes.Length];

    <span class="cm">// Nonce ngáº«u nhiĂªn má»—i láº§n â€” tuyá»‡t Ä‘á»‘i khĂ´ng tĂ¡i dĂ¹ng</span>
    RandomNumberGenerator.<span class="fn">Fill</span>(nonce);

    <span class="kw">using var</span> aesGcm = <span class="kw">new</span> <span class="fn">AesGcm</span>(_key, <span class="num">16</span>);
    aesGcm.<span class="fn">Encrypt</span>(nonce, plaintextBytes, ciphertext, tag);

    <span class="cm">// ÄĂ³ng gĂ³i: nonce[12] + tag[16] + ciphertext â†’ Base64</span>
    <span class="kw">var</span> combined = <span class="kw">new byte</span>[<span class="num">12</span> + <span class="num">16</span> + ciphertext.Length];
    Buffer.<span class="fn">BlockCopy</span>(nonce,      <span class="num">0</span>, combined, <span class="num">0</span>,           <span class="num">12</span>);
    Buffer.<span class="fn">BlockCopy</span>(tag,        <span class="num">0</span>, combined, <span class="num">12</span>,          <span class="num">16</span>);
    Buffer.<span class="fn">BlockCopy</span>(ciphertext, <span class="num">0</span>, combined, <span class="num">12</span> + <span class="num">16</span>,     ciphertext.Length);
    <span class="kw">return</span> Convert.<span class="fn">ToBase64String</span>(combined);
}

<span class="kw">public string</span> <span class="fn">Decrypt</span>(<span class="kw">string</span> encryptedBase64)
{
    <span class="kw">var</span> combined   = Convert.<span class="fn">FromBase64String</span>(encryptedBase64);
    <span class="kw">var</span> nonce      = combined[..<span class="num">12</span>];          <span class="cm">// tĂ¡ch Nonce</span>
    <span class="kw">var</span> tag        = combined[<span class="num">12</span>..<span class="num">28</span>];        <span class="cm">// tĂ¡ch Tag</span>
    <span class="kw">var</span> ciphertext = combined[<span class="num">28</span>..];          <span class="cm">// tĂ¡ch Ciphertext</span>
    <span class="kw">var</span> plaintext  = <span class="kw">new byte</span>[ciphertext.Length];

    <span class="kw">using var</span> aesGcm = <span class="kw">new</span> <span class="fn">AesGcm</span>(_key, <span class="num">16</span>);
    <span class="cm">// Verify Tag trÆ°á»›c â€” náº¿u DB bá»‹ sá»­a â†’ throw ngay</span>
    aesGcm.<span class="fn">Decrypt</span>(nonce, ciphertext, tag, plaintext);
    <span class="kw">return</span> Encoding.UTF8.<span class="fn">GetString</span>(plaintext);
}
