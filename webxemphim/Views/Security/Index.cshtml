@model webxemphim.Controllers.SecurityStatusViewModel
@{
    ViewData["Title"] = "Kiểm tra bảo mật SSTP";
}

<style>
    .security-page {
        max-width: 1000px;
        margin: 0 auto;
        padding: 32px 16px;
    }
    .security-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
    }
    .security-title {
        font-size: 2rem;
        font-weight: bold;
        color: #ffd700;
    }
    .security-subtitle {
        color: #aaa;
        font-size: 0.95rem;
        margin-top: 4px;
    }
    .score-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        border: 4px solid;
        flex-shrink: 0;
    }
    .score-number { font-size: 2rem; line-height: 1; }
    .score-label  { font-size: 0.7rem; opacity: 0.8; }
    .section-card {
        background: #232533;
        border-radius: 12px;
        padding: 20px 24px;
        margin-bottom: 20px;
        border: 1px solid #333;
    }
    .section-title {
        font-size: 1rem;
        font-weight: bold;
        color: #ffd700;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 1px solid #333;
        padding-bottom: 10px;
    }
    .check-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.92rem;
    }
    .check-row:last-child { border-bottom: none; }
    .check-label { color: #ccc; }
    .check-value { font-family: monospace; color: #fff; font-size: 0.85rem; max-width: 60%; text-align: right; word-break: break-all; }
    .badge-ok   { background: #1a472a; color: #2ecc71; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: bold; }
    .badge-warn { background: #5a3a00; color: #f39c12; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: bold; }
    .badge-fail { background: #4a0000; color: #e74c3c; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: bold; }
    .badge-info { background: #0a2a4a; color: #3498db; padding: 3px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: bold; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @@media(max-width:768px) { .grid-2 { grid-template-columns: 1fr; } }
    .checked-at { color: #666; font-size: 0.8rem; text-align: right; margin-top: 8px; }
</style>

<div class="security-page">

    @* Header *@
    <div class="security-header">
        <div class="score-circle" style="
            color: @(Model.SecurityScore >= 80 ? "#2ecc71" : Model.SecurityScore >= 50 ? "#f39c12" : "#e74c3c");
            border-color: @(Model.SecurityScore >= 80 ? "#2ecc71" : Model.SecurityScore >= 50 ? "#f39c12" : "#e74c3c");
        ">
            <span class="score-number">@Model.SecurityScore</span>
            <span class="score-label">/ 100</span>
        </div>
        <div>
            <div class="security-title">
                <i class="fas fa-shield-alt"></i> Trạng thái bảo mật SSTP
            </div>
            <div class="security-subtitle">
                Kiểm tra toàn bộ lớp bảo mật đang hoạt động trên hệ thống
            </div>
            <div style="margin-top:8px;">
                @if (Model.SecurityScore >= 80)
                {
                    <span class="badge-ok">✅ Hệ thống bảo mật tốt</span>
                }
                else if (Model.SecurityScore >= 50)
                {
                    <span class="badge-warn">⚠️ Cần cải thiện thêm</span>
                }
                else
                {
                    <span class="badge-fail">❌ Bảo mật yếu</span>
                }
                <span class="badge-info" style="margin-left:8px;">@Model.Environment</span>
            </div>
        </div>
    </div>

    <div class="grid-2">

        @* Transport Security *@
        <div class="section-card">
            <div class="section-title">
                <i class="fas fa-lock"></i> Transport Security (SSTP)
            </div>
            <div class="check-row">
                <span class="check-label">Kết nối HTTPS</span>
                <span>
                    @if (Model.TransportSecure)
                    { <span class="badge-ok">✅ Bảo mật</span> }
                    else
                    { <span class="badge-warn">⚠️ HTTP</span> }
                </span>
            </div>
            <div class="check-row">
                <span class="check-label">Request Scheme</span>
                <span class="check-value">@Model.Scheme</span>
            </div>
            <div class="check-row">
                <span class="check-label">X-Forwarded-Proto</span>
                <span class="check-value">
                    @if (!string.IsNullOrEmpty(Model.ForwardedProto))
                    { @Model.ForwardedProto }
                    else
                    { <span style="color:#666">Không có</span> }
                </span>
            </div>
            <div class="check-row">
                <span class="check-label">HSTS Header</span>
                <span>
                    @if (Model.HasHstsHeader)
                    { <span class="badge-ok">✅ Có</span> }
                    else
                    { <span class="badge-warn">⚠️ Không có</span> }
                </span>
            </div>
            <div class="check-row">
                <span class="check-label">Môi trường</span>
                <span>
                    @if (Model.IsProduction)
                    { <span class="badge-ok">✅ Production</span> }
                    else
                    { <span class="badge-warn">⚠️ Development</span> }
                </span>
            </div>
        </div>

        @* Database *@
        <div class="section-card">
            <div class="section-title">
                <i class="fas fa-database"></i> Database & Session
            </div>
            <div class="check-row">
                <span class="check-label">Kết nối Database</span>
                <span>
                    @if (Model.DatabaseConnected)
                    { <span class="badge-ok">✅ Kết nối thành công</span> }
                    else
                    { <span class="badge-fail">❌ Mất kết nối</span> }
                </span>
            </div>
            <div class="check-row">
                <span class="check-label">Mã hóa dữ liệu</span>
                <span><span class="badge-ok">✅ AES-256-GCM</span></span>
            </div>
            <div class="check-row">
                <span class="check-label">Hash mật khẩu</span>
                <span><span class="badge-ok">✅ BCrypt WF-12</span></span>
            </div>
            <div class="check-row">
                <span class="check-label">Session Cookie</span>
                <span class="check-value">@Model.SessionCookieName</span>
            </div>
            <div class="check-row">
                <span class="check-label">Session ID</span>
                <span class="check-value" style="font-size:0.75rem;">
                    @Model.SessionId.Substring(0, Math.Min(16, Model.SessionId.Length))...
                </span>
            </div>
        </div>

    </div>

    @* Security Headers *@
    <div class="section-card">
        <div class="section-title">
            <i class="fas fa-shield-virus"></i> HTTP Response Security Headers
        </div>
        <div class="grid-2">
            <div>
                <div class="check-row">
                    <span class="check-label">Content-Security-Policy</span>
                    <span>
                        @if (Model.HasCspHeader)
                        { <span class="badge-ok">✅ Có</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
                <div class="check-row">
                    <span class="check-label">X-Frame-Options</span>
                    <span>
                        @if (Model.HasXFrameHeader)
                        { <span class="badge-ok">✅ DENY</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
                <div class="check-row">
                    <span class="check-label">X-Content-Type-Options</span>
                    <span>
                        @if (Model.HasNoSniffHeader)
                        { <span class="badge-ok">✅ nosniff</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
                <div class="check-row">
                    <span class="check-label">Referrer-Policy</span>
                    <span>
                        @if (Model.HasReferrerHeader)
                        { <span class="badge-ok">✅ Có</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
            </div>
            <div>
                <div class="check-row">
                    <span class="check-label">Permissions-Policy</span>
                    <span>
                        @if (Model.HasPermHeader)
                        { <span class="badge-ok">✅ Có</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
                <div class="check-row">
                    <span class="check-label">Cross-Origin-Opener-Policy</span>
                    <span>
                        @if (Model.HasCoopHeader)
                        { <span class="badge-ok">✅ same-origin</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
                <div class="check-row">
                    <span class="check-label">Cross-Origin-Resource-Policy</span>
                    <span>
                        @if (Model.HasCorpHeader)
                        { <span class="badge-ok">✅ same-origin</span> }
                        else
                        { <span class="badge-warn">⚠️ Không có</span> }
                    </span>
                </div>
                <div class="check-row">
                    <span class="check-label">Antiforgery (CSRF)</span>
                    <span><span class="badge-ok">✅ Toàn cục</span></span>
                </div>
            </div>
        </div>
    </div>

    @* Lớp bảo mật tổng quan *@
    <div class="section-card">
        <div class="section-title">
            <i class="fas fa-layer-group"></i> 9 Lớp bảo mật Defense in Depth
        </div>
        @{
            var layers = new[]
            {
                new { No="1", Name="Transport Security (HTTPS/HSTS)",    Status=Model.TransportSecure, Note="SSTP-style — mã hóa đường truyền" },
                new { No="2", Name="HTTP Response Security Headers",     Status=Model.HasCspHeader && Model.HasXFrameHeader, Note="CSP, X-Frame, nosniff, COOP, CORP" },
                new { No="3", Name="Rate Limiting & Brute-force",        Status=true,                  Note="Login 10 req/phút, Global 200 req/phút" },
                new { No="4", Name="CSRF Protection",                    Status=true,                  Note="Antiforgery token toàn cục" },
                new { No="5", Name="Session & Cookie Security",          Status=true,                  Note="HttpOnly, SameSite=Strict" },
                new { No="6", Name="Authentication (BCrypt)",            Status=true,                  Note="BCrypt work factor 12 + Lockout 15 phút" },
                new { No="7", Name="Authorization (RBAC)",               Status=true,                  Note="Admin / User VIP / User" },
                new { No="8", Name="Encryption at Rest (AES-256-GCM)",   Status=true,                  Note="Mã hóa PII + tài chính + media URL" },
                new { No="9", Name="Secrets Management",                 Status=true,                  Note="User Secrets / Environment Variables" },
            };
        }
        @foreach (var layer in layers)
        {
            <div class="check-row">
                <span class="check-label">
                    <span style="color:#ffd700;margin-right:8px;font-weight:bold;">[@layer.No]</span>
                    @layer.Name
                    <span style="color:#666;font-size:0.8rem;margin-left:8px;">— @layer.Note</span>
                </span>
                <span>
                    @if (layer.Status)
                    { <span class="badge-ok">✅ Hoạt động</span> }
                    else
                    { <span class="badge-warn">⚠️ Chưa kích hoạt</span> }
                </span>
            </div>
        }
    </div>

    @* Request Info *@
    <div class="section-card">
        <div class="section-title">
            <i class="fas fa-info-circle"></i> Thông tin Request
        </div>
        <div class="check-row">
            <span class="check-label">Client IP</span>
            <span class="check-value">@Model.ClientIp</span>
        </div>
        <div class="check-row">
            <span class="check-label">Host</span>
            <span class="check-value">@Model.Host</span>
        </div>
        <div class="check-row">
            <span class="check-label">User Agent</span>
            <span class="check-value" style="font-size:0.75rem;">
                @(Model.UserAgent.Length > 80 ? Model.UserAgent.Substring(0, 80) + "..." : Model.UserAgent)
            </span>
        </div>
    </div>

    <div class="checked-at">
        <i class="fas fa-clock"></i> Kiểm tra lúc: @Model.CheckedAt.ToString("dd/MM/yyyy HH:mm:ss") UTC
        &nbsp;|&nbsp;
        <a href="/Security" style="color:#ffd700;">🔄 Làm mới</a>
        &nbsp;|&nbsp;
        <a href="/" style="color:#aaa;">← Trang chủ</a>
    </div>

</div>
