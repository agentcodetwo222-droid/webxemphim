<script>
    // Topic card click events
    document.querySelectorAll('.topic-card').forEach(card => {
        card.addEventListener('click', function() {
            const title = this.querySelector('.topic-title').textContent;
            console.log('Clicked topic:', title);
            // Add your navigation logic here
        });
    });

    // Topic link click events
    document.querySelectorAll('.topic-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.stopPropagation();
            const title = this.parentElement.querySelector('.topic-title').textContent;
            console.log('View all for topic:', title);
            // Add your navigation logic here
        });
    });
</script> 