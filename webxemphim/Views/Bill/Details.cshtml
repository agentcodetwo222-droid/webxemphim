@model webxemphim.Controllers.BillViewModel

@{
    ViewData["Title"] = "Chi tiết hóa đơn";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4" style="color:#ffd700;font-weight:bold;text-align:center;">
                <i class="fas fa-file-invoice-dollar" style="margin-right:10px;"></i>
                Chi tiết hóa đơn
            </h2>

            <div class="card" style="background:#232533;border:1px solid #333;">
                <div class="card-header" style="background:#1a1a1a;border-bottom:1px solid #333;">
                    <div class="d-flex justify-content-between align-items-center">
                        <span style="color:#ffd700;font-weight:bold;font-size:1.1em;">
                            <i class="fas fa-receipt" style="margin-right:8px;"></i>
                            <code style="color:#ffd700;">@Model.BillCode</code>
                        </span>
                        <span class="badge @(Model.Status == "Completed" ? "bg-success" : Model.Status == "Failed" ? "bg-danger" : "bg-warning") fs-6">
                            @Model.Status
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <div style="background:#1a1a1a;border-radius:8px;padding:16px;">
                                <div style="color:#aaa;font-size:0.8em;margin-bottom:4px;">THÔNG TIN USER</div>
                                <div style="color:#fff;font-weight:600;">@Model.UserName</div>
                                <div style="color:#ffd700;font-size:0.9em;">@Model.UserEmail</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div style="background:#1a1a1a;border-radius:8px;padding:16px;">
                                <div style="color:#aaa;font-size:0.8em;margin-bottom:4px;">DỊCH VỤ</div>
                                <div style="color:#fff;font-weight:600;">@Model.ServiceName</div>
                                <span class="badge @(Model.Type == "Deposit" ? "bg-success" : "bg-warning text-dark")">
                                    @(Model.Type == "Deposit" ? "Nạp tiền" : Model.Type == "Purchase" ? "Mua VIP" : Model.Type)
                                </span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div style="background:#1a1a1a;border-radius:8px;padding:16px;text-align:center;">
                                <div style="color:#aaa;font-size:0.8em;margin-bottom:4px;">SỐ TIỀN GỐC</div>
                                <div class="@(Model.Amount >= 0 ? "text-success" : "text-danger")" style="font-size:1.2em;font-weight:bold;">
                                    @(Model.Amount >= 0 ? "+" : "")@Model.Amount.ToString("N2") @Model.CurrencyCode
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div style="background:#1a1a1a;border-radius:8px;padding:16px;text-align:center;">
                                <div style="color:#aaa;font-size:0.8em;margin-bottom:4px;">QUY ĐỔI VNĐ</div>
                                <div class="@(Model.AmountInVND >= 0 ? "text-success" : "text-danger")" style="font-size:1.2em;font-weight:bold;">
                                    @(Model.AmountInVND >= 0 ? "+" : "")@Model.AmountInVND.ToString("N0") ₫
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div style="background:#1a1a1a;border-radius:8px;padding:16px;text-align:center;">
                                <div style="color:#aaa;font-size:0.8em;margin-bottom:4px;">SỐ DƯ SAU</div>
                                <div style="color:#ffd700;font-size:1.2em;font-weight:bold;">
                                    @Model.BalanceAfter.ToString("N0") ₫
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div style="background:#1a1a1a;border-radius:8px;padding:16px;">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div style="color:#aaa;font-size:0.8em;">Số dư trước</div>
                                        <div style="color:#fff;">@Model.BalanceBefore.ToString("N0") ₫</div>
                                    </div>
                                    <div class="col-md-4">
                                        <div style="color:#aaa;font-size:0.8em;">Mã giao dịch</div>
                                        <div style="color:#fff;font-size:0.9em;">@Model.TransactionId</div>
                                    </div>
                                    <div class="col-md-4">
                                        <div style="color:#aaa;font-size:0.8em;">Ngày tạo</div>
                                        <div style="color:#fff;">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="col-12">
                                <div style="background:#1a1a1a;border-radius:8px;padding:16px;">
                                    <div style="color:#aaa;font-size:0.8em;margin-bottom:4px;">GHI CHÚ</div>
                                    <div style="color:#fff;">@Model.Note</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a href="/Bill" class="btn btn-secondary">
                    <i class="fas fa-arrow-left" style="margin-right:5px;"></i>Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>
